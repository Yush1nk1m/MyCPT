# 터미널에 명령어 자체가 출력되는 것을 방지하기 위해 @를 붙임

up:
	@./docker-compose-ctl.sh up all

down:
	@./docker-compose-ctl.sh down all

start:
	@./docker-compose-ctl.sh start all

stop:
	@./docker-compose-ctl.sh stop all

restart:
	@./docker-compose-ctl.sh restart all

clean:
	@./docker-compose-ctl.sh clean all

status:
	@./docker-compose-ctl.sh status

# ── profile별 단축 타겟 ──────────────────────────────────────
up-frontend:
	@./docker-compose-ctl.sh up frontend

down-frontend:
	@./docker-compose-ctl.sh down frontend

up-infra:
	@./docker-compose-ctl.sh up infra

down-infra:
	@./docker-compose-ctl.sh down infra