@startuml MyCPT_UseCase

left to right direction
skinparam backgroundColor #FAFAFA

skinparam actor {
  BackgroundColor #FFFFFF
  BorderColor #7F77DD
  FontColor #3C3489
  FontSize 13
  FontStyle bold
}

skinparam usecase {
  BackgroundColor #FFFFFF
  BorderColor #AFA9EC
  FontColor #26215C
  FontSize 12
  BorderThickness 1.5
  ArrowColor #7F77DD
  ArrowFontColor #534AB7
  ArrowFontSize 10
}

skinparam package {
  BackgroundColor #EEEDFE
  BorderColor #534AB7
  BorderThickness 2
  FontColor #3C3489
  FontSize 14
  FontStyle bold
}

skinparam note {
  BackgroundColor #F5F3FF
  BorderColor #AFA9EC
  FontColor #534AB7
  FontSize 10
}

skinparam linetype ortho

actor "비회원" as Guest
actor "회원 (카카오)" as Member
actor "배치 스케줄러" as Batch

rectangle "MyCPT 시스템" {

  package "공통 기능" #EEF6FF {
    usecase "검사 응시\n횟수 제한 없음" as UC_Test
    usecase "결과 확인\nDISC 분석 · 강점 · 약점" as UC_Result
    usecase "로그인 후 결과 저장" as UC_Save
  }

  package "회원 전용 기능" #F0FDF4 {
    usecase "카카오 로그인 / 로그아웃" as UC_Login
    usecase "결과 이력 조회" as UC_History
    usecase "타인 통계 비교\n나이대 · 성별 기준" as UC_Stats
    usecase "동료 코드 생성" as UC_Code
    usecase "케미\n동료 케미 보고서 발행" as UC_Compat
  }

  package "시스템 내부" #FFF7ED {
    usecase "LLM 캐시 조회 / 저장\nD · I · S · C 버킷 기반 (9⁴ = 6,561)" as UC_Cache
    usecase "캐시 초기화" as UC_Clear
  }
}

Guest  --> UC_Test
Guest  --> UC_Result
Guest  --> UC_Save

Member --> UC_Test
Member --> UC_Result
Member --> UC_Login
Member --> UC_History
Member --> UC_Stats
Member --> UC_Code
Member --> UC_Compat  : 코인 1개 소모

Batch  --> UC_Clear   : 1 ~ 2달 주기

UC_Result ..> UC_Cache : <<include>>
UC_Save   ..> UC_Login : <<include>>

note right of UC_Cache
  캐시 미스 시에만 LLM API 호출
  캐시 히트 시 DB에서 즉시 반환
  → 최대 6,561회 API 호출로 전체 커버
end note

note right of UC_Compat
  캐싱 없이 매번 실시간 LLM 호출
  정확도 우선 설계
  코인 충전: 초기 3개 지급
  이후 24h마다 +1, 최대 3개 보유
end note

note bottom of UC_Test
  검사 완료 후 나이(출생연도) · 성별 입력
  비회원: 통계 반영은 로그인 저장 시에만 적용
end note

@enduml