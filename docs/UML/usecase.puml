@startuml MyCPT_UseCase

left to right direction
skinparam backgroundColor #FAFAFA

skinparam actor {
  BackgroundColor #FFFFFF
  BorderColor #7F77DD
  FontColor #3C3489
  FontSize 13
  FontStyle bold
}

skinparam usecase {
  BackgroundColor #FFFFFF
  BorderColor #AFA9EC
  FontColor #26215C
  FontSize 12
  BorderThickness 1.5
  ArrowColor #7F77DD
  ArrowFontColor #534AB7
  ArrowFontSize 10
}

skinparam package {
  BackgroundColor #EEEDFE
  BorderColor #534AB7
  BorderThickness 2
  FontColor #3C3489
  FontSize 14
  FontStyle bold
}

skinparam note {
  BackgroundColor #F5F3FF
  BorderColor #AFA9EC
  FontColor #534AB7
  FontSize 10
}

skinparam linetype ortho

actor "비회원" as Guest
actor "회원 (카카오)" as Member
actor "배치 스케줄러" as Batch

rectangle "MyCPT 시스템" {

  package "공통 기능" #EEF6FF {
    usecase "검사 응시\n횟수 제한 없음" as UC_Test
    usecase "결과 확인\nDISC 분석 · 강점 · 약점 등 6개 섹션" as UC_Result
    usecase "로그인 후 결과 저장" as UC_Save
  }

  package "회원 전용 기능" #F0FDF4 {
    usecase "카카오 로그인 / 로그아웃" as UC_Login
    usecase "결과 이력 조회" as UC_History
    usecase "타인 통계 비교\n나이대 · 성별 기준" as UC_Stats
    usecase "동료 초대 코드 생성\n대문자+숫자 8자리 · 다회용 · 7일 갱신" as UC_Code
    usecase "동료 초대 및 등록\n링크 공유 또는 코드 직접 입력\n수락 시 양방향 관계 생성" as UC_ColleagueRegister
    usecase "동료 케미 보고서 발행\n동료 목록에서 대상 선택 · 6개 섹션" as UC_Compat
    usecase "인앱 알림 확인\n클릭 시 즉시 삭제" as UC_Notify
  }

  package "시스템 내부" #FFF7ED {
    usecase "LLM 캐시 조회 / 저장\nD · I · S · C 버킷 기반 (9⁴ = 6,561)\n온디맨드 만료 · 행 UPDATE 갱신" as UC_Cache
    usecase "만료 동료 코드 삭제" as UC_PeerCodeClean
  }
}

Guest  --> UC_Test
Guest  --> UC_Result
Guest  --> UC_Save

Member --> UC_Test
Member --> UC_Result
Member --> UC_Login
Member --> UC_History
Member --> UC_Stats
Member --> UC_Code
Member --> UC_ColleagueRegister
Member --> UC_Compat      : 코인 1개 소모
Member --> UC_Notify

Batch  --> UC_PeerCodeClean : 주기적 실행

UC_Result ..> UC_Cache  : <<include>>
UC_Save   ..> UC_Login  : <<include>>
UC_Compat ..> UC_Notify : <<include>>

note right of UC_Cache
  캐시 미스 → LLM 호출 → INSERT
  캐시 히트 + 유효 → 즉시 반환
  캐시 히트 + 만료 → LLM 호출 → UPDATE
  보고서 원문에 이름 미포함 저장
  렌더링 시 이름 삽입
end note

note right of UC_Compat
  캐싱 없이 매번 실시간 LLM 호출
  발행 시점 DISC 스냅샷 저장
  보고서 원문에 이름 미포함 저장
  코인 충전: 초기 3개 지급
  이후 24h마다 +1 (온디맨드), 최대 3개
end note

note right of UC_Code
  보안: 7일 주기 갱신으로
  코드 유추를 통한 타인 성향
  열람 방지
end note

note bottom of UC_Test
  검사 완료 후 나이(출생연도) · 성별 입력 (최초 1회)
  비회원: D/I/S/C 버킷값을 세션에 임시 저장
  로그인 후 DB에 저장 및 통계 반영
end note

@enduml